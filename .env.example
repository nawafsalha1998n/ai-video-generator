# Replicate API Token
REPLICATE_API_TOKEN=your_replicate_api_token_here

# Database Configuration (Optional for public users)
DATABASE_URL=mysql://user:password@localhost:3306/ai_video_generator

# OAuth Configuration (Optional)
OAUTH_SERVER_URL=https://your-oauth-server.com
OWNER_OPEN_ID=your_owner_id

# JWT Secret for Cookies
JWT_SECRET=your_jwt_secret_key_here

# Forge API (Optional)
BUILT_IN_FORGE_API_URL=https://api.forge.com
BUILT_IN_FORGE_API_KEY=your_forge_api_key

# App Configuration
VITE_APP_ID=ai-video-generator
NODE_ENV=production
